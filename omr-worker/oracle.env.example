# Copy this to oracle.env, fill in the OCIDs, then:
#   set -a; . ./oracle.env; set +a; ./oracle-launch.sh
#
# oracle.env is gitignored. These are account-specific resource IDs, not secrets,
# but they are still not committed. See ORACLE.md for how to find each value.
#
# None of these values incur cost: every shape below is inside Oracle Always Free.

# --- required ---------------------------------------------------------------

# Compartment OCID to create the instance in. For a personal tenancy this is often
# the tenancy root compartment OCID.
#   oci iam compartment list --query 'data[].{name:name,id:id}' --output table
#   (root: `oci iam compartment list --compartment-id-in-subtree true ...` or use the
#    tenancy OCID from `oci iam compartment list --access-level ACCESSIBLE`)
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx

# Subnet OCID (a PUBLIC subnet in your VCN, so the VM gets a public IP).
#   oci network subnet list --compartment-id "$OCI_COMPARTMENT_ID" \
#     --query 'data[].{name:"display-name",id:id}' --output table
OCI_SUBNET_ID=ocid1.subnet.oc1.<region>.xxxxx

# Image OCID for Canonical Ubuntu 22.04 aarch64 (ARM) in YOUR region.
#   oci compute image list --compartment-id "$OCI_COMPARTMENT_ID" \
#     --operating-system "Canonical Ubuntu" --operating-system-version "22.04" \
#     --shape VM.Standard.A1.Flex \
#     --query 'data[0].{name:"display-name",id:id}' --output table
OCI_IMAGE_ID=ocid1.image.oc1.<region>.xxxxx

# Availability domain NAME (not OCID), e.g. "AbCd:EU-MADRID-1-AD-1".
#   oci iam availability-domain list --query 'data[].name' --output table
OCI_AD=AbCd:EU-MADRID-1-AD-1

# Path to your SSH PUBLIC key (the .pub). Generate with:
#   ssh-keygen -t ed25519 -f ~/.ssh/oci_omr -C piano-helper-omr
OCI_SSH_KEY_PATH=~/.ssh/oci_omr.pub

# --- optional (defaults are the full Always Free ARM allotment) --------------

# OCI_SHAPE=VM.Standard.A1.Flex
# OCI_OCPUS=4
# OCI_MEM_GB=24
# OCI_DISPLAY_NAME=piano-helper-omr
# OCI_BOOT_VOLUME_GB=50
# OCI_PROFILE=DEFAULT
# RETRY_SLEEP_MIN=30
# RETRY_SLEEP_MAX=90
# MAX_ATTEMPTS=0     # 0 = retry forever
