{
  "name": "piano-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Turn piano sheet music into a falling-notes visual performance.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
