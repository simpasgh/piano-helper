    "opensheetmusicdisplay": "^1.9.0",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  }
}
